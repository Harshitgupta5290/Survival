; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but for reference, here's the complete format:
;
; [section] ; section goes between []
; param=value ; assign values to parameters

config_version=5

[application]

config/name="Survival: Hunter Chronicles"
config/description="A thrilling 2D side-scrolling action shooter. Fight your way through enemy hordes, collect power-ups, and survive!"
run/main_scene="res://scenes/main_menu.tscn"
config/features=PackedStringArray("4.2", "Forward Plus")
config/icon="res://assets/img/icons/bullet.png"

[autoload]

Constants="*res://scripts/constants.gd"
GameManager="*res://scripts/game_manager.gd"
AudioManager="*res://scripts/audio_manager.gd"
InputManager="*res://scripts/input_manager.gd"

[display]

window/size/viewport_width=800
window/size/viewport_height=640
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[physics]

2d/default_gravity=980.0

[rendering]

textures/canvas_textures/default_texture_filter=0

[input]

